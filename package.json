{
	"name": "xiaohongshu-importer-standalone",
	"version": "2.0.0",
	"description": "Standalone Xiaohongshu importer with AI-powered categorization",
	"main": "dist/index.js",
	"bin": {
		"xhs-import": "dist/cli.js"
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/cli.js",
		"test": "jest",
	"test:watch": "jest --watch",
	"test:coverage": "jest --coverage",
		"demo": "node dist/cli.js interactive"
	},
	"keywords": [
		"xiaohongshu",
		"importer",
		"ai",
		"markdown",
		"standalone"
	],
	"author": "bnchiang96",
	"license": "MIT",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1000.0",
		"@aws-sdk/lib-storage": "^3.1000.0",
		"chalk": "^5.3.0",
		"commander": "^11.0.0",
		"inquirer": "^9.2.0",
		"node-fetch": "^3.3.2",
		"openai": "^4.20.0",
		"ora": "^7.0.0"
	},
	"devDependencies": {
		"@types/inquirer": "^9.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.0.0",
		"jest": "^30.2.0",
		"ts-jest": "^29.4.6",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0"
	},
	"engines": {
		"node": ">=16.0.0"
	}
}
